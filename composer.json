{
  "name": "chauhan-mukesh/studio-todo-bundle",
  "description": "A production-grade todo management bundle for Pimcore 12 with Studio UI integration",
  "type": "pimcore-bundle",
  "license": "MIT",
  "keywords": ["pimcore", "pimcore-bundle", "todo", "task-management", "studio-ui"],
  "authors": [
    {
      "name": "Mukesh Chauhan",
      "email": "mukesh@example.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "pimcore/pimcore": "^11.0 || ^12.0",
    "symfony/messenger": "^6.4 || ^7.0",
    "doctrine/dbal": "^3.0 || ^4.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0",
    "symfony/phpunit-bridge": "^6.4 || ^7.0"
  },
  "autoload": {
    "psr-4": {
      "ChauhanMukesh\\StudioTodoBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ChauhanMukesh\\StudioTodoBundle\\Tests\\": "tests/"
    }
  },
  "extra": {
    "pimcore": {
      "bundles": [
        "ChauhanMukesh\\StudioTodoBundle\\StudioTodoBundle"
      ]
    }
  }
}
